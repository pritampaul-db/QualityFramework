{
  "name": "dq_framework_sdp_daily",
  "description": "Daily DQ Framework execution using Spark Declarative Pipelines (DLT)",
  "tasks": [
    {
      "task_key": "00_verify_setup",
      "description": "Verify Bronze tables and prerequisites",
      "notebook_task": {
        "notebook_path": "sdp_poc/notebooks/00_sdp_setup"
      },
      "existing_cluster_id": "{{ cluster_id }}"
    },
    {
      "task_key": "01_run_dlt_pipeline",
      "description": "Run the DLT pipeline (Bronze → Silver validated/clean/quarantine → Gold)",
      "depends_on": [
        {"task_key": "00_verify_setup"}
      ],
      "pipeline_task": {
        "pipeline_id": "{{ pipeline_id }}",
        "full_refresh": false
      }
    },
    {
      "task_key": "02_dq_analysis",
      "description": "Generate DQ analysis results and row-level reports",
      "depends_on": [
        {"task_key": "01_run_dlt_pipeline"}
      ],
      "notebook_task": {
        "notebook_path": "sdp_poc/notebooks/02_sdp_dq_analysis"
      },
      "existing_cluster_id": "{{ cluster_id }}"
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 6 * * ?",
    "timezone_id": "UTC",
    "pause_status": "PAUSED"
  },
  "email_notifications": {
    "on_failure": ["{{ alert_email }}"]
  },
  "max_concurrent_runs": 1,
  "tags": {
    "framework": "dq_sdp",
    "team": "data_quality"
  }
}
